{
  "name": "bookly-api",
  "version": "1.0.0",
  "description": "Bookly - Production-ready Booking Appointment SaaS API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node --experimental-strip-types src/server.js",
    "dev": "node --experimental-strip-types --watch src/server.js",
    "db:migrate": "npx prisma migrate dev --schema=src/prisma/schema.prisma",
    "db:migrate:deploy": "npx prisma migrate deploy --schema=src/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=src/prisma/schema.prisma",
    "db:seed": "node --env-file=.env src/prisma/seed.js",
    "db:studio": "npx prisma studio --schema=src/prisma/schema.prisma",
    "db:reset": "npx prisma migrate reset --schema=src/prisma/schema.prisma",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^172.0.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
